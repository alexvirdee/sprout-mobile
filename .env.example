# Sprout mobile — copy to `.env` and set your API URL.
#
# Base URL of the Sprout backend API. IMPORTANT for device testing:
# `localhost` on a physical phone points at the phone, not your Mac.
#   iOS simulator / web : http://localhost:4000/api
#   Android emulator    : http://10.0.2.2:4000/api
#   Physical device     : http://YOUR_LOCAL_IP:4000/api   (phone + Mac on the same Wi-Fi)
#
# Find your Mac's LAN IP:  ipconfig getifaddr en0   (or System Settings → Network)
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:4000/api

# Google OAuth client IDs (groundwork — not in scope yet)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
