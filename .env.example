# Sprout mobile — environment example
# Copy to `.env` (or set via app.json > expo.extra) and fill in.

# Base URL of the Sprout backend API.
# iOS simulator can use localhost; Android emulator uses 10.0.2.2.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Google OAuth client IDs (groundwork — see README "Google OAuth setup").
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
